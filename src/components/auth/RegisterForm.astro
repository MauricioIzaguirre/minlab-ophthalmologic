---
import { isInputError } from 'astro:actions';
import { server as actions } from '../../actions/index.js';

// Obtener resultado de la action si existe
const result = Astro.getActionResult(actions.auth.register);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
---

<div class="card w-full">
  <header>
    <h2>Crear tu cuenta</h2>
    <p>Completa los siguientes datos para crear tu nueva cuenta</p>
  </header>
  
  <!-- Mensaje de error general -->
  {result?.error && !isInputError(result.error) && (
    <div class="bg-destructive/10 border border-destructive/20 text-destructive px-4 py-3 rounded-md mb-4">
      <p class="text-sm">{result.error.message}</p>
    </div>
  )}
  
  <!-- Mensaje de éxito -->
  {result && !result.error && (
    <div class="bg-primary/10 border border-primary/20 text-primary px-4 py-3 rounded-md mb-4">
      <p class="text-sm">¡Cuenta creada exitosamente! Redirigiendo...</p>
    </div>
  )}
  
  <section>
    <form method="POST" action={actions.auth.register} class="form grid gap-6" id="register-form">
      <div class="grid grid-cols-2 gap-4">
        <div class="grid gap-2">
          <label for="firstName">Nombre</label>
          <input 
            type="text" 
            id="firstName" 
            name="firstName"
            placeholder="Tu nombre"
            required
            class={inputErrors.firstName ? 'border-destructive focus:ring-destructive' : ''}
          />
          {inputErrors.firstName && (
            <p class="text-sm text-destructive">{inputErrors.firstName.join(', ')}</p>
          )}
        </div>
        <div class="grid gap-2">
          <label for="lastName">Apellido</label>
          <input 
            type="text" 
            id="lastName" 
            name="lastName"
            placeholder="Tu apellido"
            required
            class={inputErrors.lastName ? 'border-destructive focus:ring-destructive' : ''}
          />
          {inputErrors.lastName && (
            <p class="text-sm text-destructive">{inputErrors.lastName.join(', ')}</p>
          )}
        </div>
      </div>
      
      <div class="grid gap-2">
        <label for="email">Email</label>
        <input 
          type="email" 
          id="email" 
          name="email"
          placeholder="tu@email.com"
          required
          class={inputErrors.email ? 'border-destructive focus:ring-destructive' : ''}
        />
        {inputErrors.email && (
          <p class="text-sm text-destructive">{inputErrors.email.join(', ')}</p>
        )}
      </div>
      
      <div class="grid gap-2">
        <label for="password">Contraseña</label>
        <input 
          type="password" 
          id="password" 
          name="password"
          placeholder="Mínimo 8 caracteres"
          required
          class={inputErrors.password ? 'border-destructive focus:ring-destructive' : ''}
        />
        {inputErrors.password && (
          <p class="text-sm text-destructive">{inputErrors.password.join(', ')}</p>
        )}
        <div class="text-xs text-muted-foreground">
          • Al menos 8 caracteres
          • Una mayúscula, una minúscula y un número
        </div>
      </div>
      
      <div class="grid gap-2">
        <label for="confirmPassword">Confirmar contraseña</label>
        <input 
          type="password" 
          id="confirmPassword" 
          name="confirmPassword"
          placeholder="Confirma tu contraseña"
          required
          class={inputErrors.confirmPassword ? 'border-destructive focus:ring-destructive' : ''}
        />
        {inputErrors.confirmPassword && (
          <p class="text-sm text-destructive">{inputErrors.confirmPassword.join(', ')}</p>
        )}
      </div>
      
      <div class="flex items-center space-x-2">
        <input 
          type="checkbox" 
          id="terms" 
          name="terms"
          value="true"
          required 
          class="rounded"
        />
        <label for="terms" class="text-sm">
          Acepto los 
          <a href="/terms" class="underline underline-offset-4 hover:text-primary">Términos de Servicio</a> 
          y la 
          <a href="/privacy" class="underline underline-offset-4 hover:text-primary">Política de Privacidad</a>
        </label>
      </div>
      {inputErrors.terms && (
        <p class="text-sm text-destructive">{inputErrors.terms.join(', ')}</p>
      )}
    </form>
  </section>
  
  <footer class="flex flex-col items-center gap-2">
    <button type="submit" form="register-form" class="btn w-full">
      Crear cuenta
    </button>
    
    <p class="mt-4 text-center text-sm">
      ¿Ya tienes cuenta? 
      <a href="/auth/login" class="underline underline-offset-4 hover:underline">Inicia sesión</a>
    </p>
  </footer>
</div>

<script>
  // Redireccionar en caso de éxito
  const successMessage = document.querySelector('.bg-primary\\/10') as HTMLElement | null;
  if (successMessage) {
    setTimeout(() => {
      window.location.href = '/dashboard';
    }, 1500);
  }
  
  // Validación en tiempo real de contraseñas
  const password = document.getElementById('password') as HTMLInputElement | null;
  const confirmPassword = document.getElementById('confirmPassword') as HTMLInputElement | null;
  const form = document.querySelector('form') as HTMLFormElement | null;
  const submitButton = document.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  
  // Validar que las contraseñas coincidan
  function validatePasswords() {
    if (password && confirmPassword) {
      if (password.value && confirmPassword.value && password.value !== confirmPassword.value) {
        confirmPassword.setCustomValidity('Las contraseñas no coinciden');
      } else {
        confirmPassword.setCustomValidity('');
      }
    }
  }
  
  password?.addEventListener('input', validatePasswords);
  confirmPassword?.addEventListener('input', validatePasswords);
  
  // Manejo del formulario
  form?.addEventListener('submit', function(e) {
    validatePasswords();
    if (submitButton) {
      submitButton.textContent = 'Creando cuenta...';
      submitButton.disabled = true;
    }
  });
</script>