---
import { isInputError } from 'astro:actions';
import { server as actions } from '../../actions/index.js';

// Obtener resultado de la action si existe
const result = Astro.getActionResult(actions.auth.forgotPassword);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
---

<div class="card w-full">
  <header>
    <h2>Recuperar contraseña</h2>
    <p>Ingresa tu email y te enviaremos un enlace para restablecer tu contraseña</p>
  </header>
  
  <!-- Mensaje de error general -->
  {result?.error && !isInputError(result.error) && (
    <div class="bg-destructive/10 border border-destructive/20 text-destructive px-4 py-3 rounded-md mb-4">
      <p class="text-sm">{result.error.message}</p>
    </div>
  )}
  
  <!-- Mensaje de éxito -->
  {result && !result.error && (
    <div class="bg-primary/10 border border-primary/20 text-primary px-4 py-3 rounded-md mb-4">
      <div class="flex items-center gap-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10">
          <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-primary">Revisa tu email</h3>
          <p class="text-sm text-primary/80">{result.data.message}</p>
        </div>
      </div>
    </div>
  )}
  
  <!-- Mostrar formulario solo si no hay éxito -->
  {!(result && !result.error) && (
    <section>
      <form method="POST" action={actions.auth.forgotPassword} class="form grid gap-6" id="forgot-password-form">
        <div class="grid gap-2">
          <label for="email">Email</label>
          <input 
            type="email" 
            id="email" 
            name="email"
            placeholder="tu@email.com"
            required
            class={inputErrors.email ? 'border-destructive focus:ring-destructive' : ''}
          />
          {inputErrors.email && (
            <p class="text-sm text-destructive">{inputErrors.email.join(', ')}</p>
          )}
        </div>
      </form>
    </section>
  )}
  
  <footer class="flex flex-col items-center gap-2">
    {!(result && !result.error) ? (
      <button type="submit" form="forgot-password-form" class="btn w-full">
        Enviar enlace de recuperación
      </button>
    ) : (
      <button type="button" class="btn w-full" onclick="window.location.reload()">
        Enviar otro enlace
      </button>
    )}
    
    <div class="flex items-center gap-2 mt-4">
      <a href="/auth/login" class="text-sm text-center underline underline-offset-4 hover:text-primary">
        ← Volver al inicio de sesión
      </a>
    </div>
  </footer>
</div>

<script>
  // Manejo del formulario
  const form = document.querySelector('form') as HTMLFormElement | null;
  const submitButton = document.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  
  form?.addEventListener('submit', function(e) {
    if (submitButton) {
      submitButton.textContent = 'Enviando...';
      submitButton.disabled = true;
    }
  });
  
  // Auto-focus en el input de email
  const emailInput = document.getElementById('email') as HTMLInputElement | null;
  if (emailInput && !emailInput.value) {
    emailInput.focus();
  }
</script>