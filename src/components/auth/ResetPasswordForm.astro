---
import { isInputError } from 'astro:actions';
import { server as actions } from '../../actions/index.js';

// Obtener token de la URL
const token = Astro.url.searchParams.get('token');

// Verificar que existe el token
if (!token) {
  return Astro.redirect('/auth/forgot-password');
}

// Obtener resultado de la action si existe
const result = Astro.getActionResult(actions.auth.resetPassword);
const inputErrors = isInputError(result?.error) ? result.error.fields : {};
---

<div class="card w-full">
  <header>
    <h2>Nueva contraseña</h2>
    <p>Ingresa tu nueva contraseña para completar el proceso de recuperación</p>
  </header>
  
  <!-- Mensaje de error general -->
  {result?.error && !isInputError(result.error) && (
    <div class="bg-destructive/10 border border-destructive/20 text-destructive px-4 py-3 rounded-md mb-4">
      <p class="text-sm">{result.error.message}</p>
    </div>
  )}
  
  <!-- Mensaje de éxito -->
  {result && !result.error && (
    <div class="bg-primary/10 border border-primary/20 text-primary px-4 py-3 rounded-md mb-4">
      <div class="flex items-center gap-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10">
          <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-primary">Contraseña actualizada</h3>
          <p class="text-sm text-primary/80">{result.data.message}</p>
        </div>
      </div>
    </div>
  )}
  
  <!-- Mostrar formulario solo si no hay éxito -->
  {!(result && !result.error) && (
    <section>
      <form method="POST" action={actions.auth.resetPassword} class="form grid gap-6" id="reset-password-form">
        <!-- Token oculto -->
        <input type="hidden" name="token" value={token} />
        
        <div class="grid gap-2">
          <label for="password">Nueva contraseña</label>
          <input 
            type="password" 
            id="password" 
            name="password"
            placeholder="Ingresa tu nueva contraseña"
            required
            class={inputErrors.password ? 'border-destructive focus:ring-destructive' : ''}
          />
          {inputErrors.password && (
            <p class="text-sm text-destructive">{inputErrors.password.join(', ')}</p>
          )}
          <p class="text-xs text-muted-foreground">La contraseña debe tener al menos 8 caracteres</p>
        </div>
        
        <div class="grid gap-2">
          <label for="confirmPassword">Confirmar nueva contraseña</label>
          <input 
            type="password" 
            id="confirmPassword" 
            name="confirmPassword"
            placeholder="Confirma tu nueva contraseña"
            required
            class={inputErrors.confirmPassword ? 'border-destructive focus:ring-destructive' : ''}
          />
          {inputErrors.confirmPassword && (
            <p class="text-sm text-destructive">{inputErrors.confirmPassword.join(', ')}</p>
          )}
        </div>
        
        <!-- Indicador de fortaleza de contraseña -->
        <div class="grid gap-2">
          <div class="flex justify-between items-center">
            <span class="text-xs text-muted-foreground">Fortaleza de contraseña</span>
            <span class="text-xs text-muted-foreground" id="strength-text">Débil</span>
          </div>
          <div class="w-full bg-muted rounded-full h-2">
            <div class="bg-destructive h-2 rounded-full transition-all duration-300" id="strength-bar" style="width: 0%"></div>
          </div>
        </div>
        
        <!-- Lista de requisitos -->
        <div class="grid gap-2 text-xs">
          <p class="text-muted-foreground">Tu contraseña debe contener:</p>
          <ul class="space-y-1 ml-4">
            <li class="flex items-center gap-2" id="length-check">
              <span class="text-muted-foreground" id="length-icon">•</span>
              <span class="text-muted-foreground" id="length-text">Al menos 8 caracteres</span>
            </li>
            <li class="flex items-center gap-2" id="uppercase-check">
              <span class="text-muted-foreground" id="uppercase-icon">•</span>
              <span class="text-muted-foreground" id="uppercase-text">Una letra mayúscula</span>
            </li>
            <li class="flex items-center gap-2" id="number-check">
              <span class="text-muted-foreground" id="number-icon">•</span>
              <span class="text-muted-foreground" id="number-text">Un número</span>
            </li>
          </ul>
        </div>
      </form>
    </section>
  )}
  
  <footer class="flex flex-col items-center gap-2">
    {!(result && !result.error) ? (
      <button type="submit" form="reset-password-form" class="btn w-full" id="reset-btn" disabled>
        Actualizar contraseña
      </button>
    ) : (
      <a href="/auth/login" class="btn w-full text-center">
        Iniciar sesión
      </a>
    )}
    
    <p class="mt-4 text-center text-sm">
      ¿Recordaste tu contraseña? 
      <a href="/auth/login" class="underline underline-offset-4 hover:underline">Volver al inicio</a>
    </p>
  </footer>
</div>

<script>
  const passwordInput = document.getElementById('password') as HTMLInputElement | null;
  const confirmPasswordInput = document.getElementById('confirmPassword') as HTMLInputElement | null;
  const strengthBar = document.getElementById('strength-bar') as HTMLElement | null;
  const strengthText = document.getElementById('strength-text') as HTMLElement | null;
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement | null;
  const form = document.querySelector('form') as HTMLFormElement | null;
  
  // Elementos de verificación
  const lengthCheck = document.getElementById('length-check') as HTMLElement | null;
  const uppercaseCheck = document.getElementById('uppercase-check') as HTMLElement | null;
  const numberCheck = document.getElementById('number-check') as HTMLElement | null;
  
  function updateRequirement(element: HTMLElement | null, passed: boolean): void {
    if (!element) return;
    
    const icon = element.querySelector('span:first-child') as HTMLSpanElement | null;
    const text = element.querySelector('span:last-child') as HTMLSpanElement | null;
    
    if (passed) {
      if (icon) {
        icon.textContent = '✓';
        icon.className = 'text-primary';
      }
      if (text) {
        text.className = 'text-primary';
      }
    } else {
      if (icon) {
        icon.textContent = '•';
        icon.className = 'text-muted-foreground';
      }
      if (text) {
        text.className = 'text-muted-foreground';
      }
    }
  }
  
  function validatePassword(): void {
    const password = passwordInput?.value || '';
    const confirmPassword = confirmPasswordInput?.value || '';
    
    // Verificar requisitos
    const hasLength = password.length >= 8;
    const hasUppercase = /[A-Z]/.test(password);
    const hasNumber = /\d/.test(password);
    const passwordsMatch = password === confirmPassword && password.length > 0;
    
    // Actualizar indicadores visuales
    updateRequirement(lengthCheck, hasLength);
    updateRequirement(uppercaseCheck, hasUppercase);
    updateRequirement(numberCheck, hasNumber);
    
    // Calcular fortaleza
    let strength = 0;
    if (hasLength) strength += 1;
    if (hasUppercase) strength += 1;
    if (hasNumber) strength += 1;
    if (password.length >= 12) strength += 1;
    if (/[!@#$%^&*(),.?":{}|<>]/.test(password)) strength += 1;
    
    // Actualizar barra de fortaleza
    const percentage = (strength / 5) * 100;
    if (strengthBar && strengthText) {
      strengthBar.style.width = `${percentage}%`;
      
      if (percentage < 40) {
        strengthBar.className = 'bg-destructive h-2 rounded-full transition-all duration-300';
        strengthText.textContent = 'Débil';
      } else if (percentage < 80) {
        strengthBar.className = 'bg-yellow-500 h-2 rounded-full transition-all duration-300';
        strengthText.textContent = 'Medio';
      } else {
        strengthBar.className = 'bg-primary h-2 rounded-full transition-all duration-300';
        strengthText.textContent = 'Fuerte';
      }
    }
    
    // Habilitar/deshabilitar botón
    const isValid = hasLength && hasUppercase && hasNumber && passwordsMatch;
    if (resetBtn) {
      resetBtn.disabled = !isValid;
    }
    
    // Validar coincidencia de contraseñas
    if (confirmPasswordInput) {
      if (confirmPassword && !passwordsMatch) {
        confirmPasswordInput.setCustomValidity('Las contraseñas no coinciden');
      } else {
        confirmPasswordInput.setCustomValidity('');
      }
    }
  }
  
  // Event listeners
  passwordInput?.addEventListener('input', validatePassword);
  confirmPasswordInput?.addEventListener('input', validatePassword);
  
  // Manejo del formulario
  form?.addEventListener('submit', function(e) {
    if (resetBtn) {
      resetBtn.textContent = 'Actualizando...';
      resetBtn.disabled = true;
    }
  });
  
  // Auto-redirigir en caso de éxito
  const successMessage = document.querySelector('.bg-primary\\/10') as HTMLElement | null;
  if (successMessage) {
    setTimeout(() => {
      window.location.href = '/auth/login?message=password-reset';
    }, 3000);
  }
</script>