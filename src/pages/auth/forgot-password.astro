---
import ForgotPasswordForm from "../../components/auth/ForgotPasswordForm.astro";
import AuthLayout from "../../layouts/AuthLayout.astro";

// Si ya está autenticado, redirigir
if (Astro.locals.isAuthenticated) {
  return Astro.redirect('/dashboard');
}
---

<AuthLayout 
  title="Recuperar Contraseña | MinLab Ophthalmologic"
  description="Recupera el acceso a tu cuenta de forma segura"
>
  <ForgotPasswordForm />
</AuthLayout>
