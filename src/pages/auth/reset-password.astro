<!-- src/pages/auth/reset-password.astro -->
---
import ResetPasswordForm from "../../components/auth/ResetPasswordForm.astro";
import AuthLayout from "../../layouts/AuthLayout.astro";

// Si ya está autenticado, redirigir
if (Astro.locals.isAuthenticated) {
  return Astro.redirect('/dashboard');
}

// Verificar que existe el token
const token = Astro.url.searchParams.get('token');
if (!token) {
  return Astro.redirect('/auth/forgot-password?error=invalid-token');
}
---

<AuthLayout 
  title="Nueva Contraseña | MinLab Ophthalmologic"
  description="Establece una nueva contraseña para tu cuenta"
>
  <ResetPasswordForm />
</AuthLayout>
